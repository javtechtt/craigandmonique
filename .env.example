# Wedding template — environment variables
# Copy this file to `.env.local` and fill in the values.
# Anything left blank disables the feature gracefully.

# --- Supabase (RSVP storage + admin dashboard) -----------------------------
# Project URL + service role key, available in your Supabase project under
# Settings → API. The service key is server-only — never expose it to the
# client. The schema lives in `supabase/schema.sql`.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Resend (email notification when an RSVP comes in) ---------------------
# 1. Sign up at resend.com (free tier: 100 emails/day, no card required)
# 2. Add and verify your domain (or skip and use the test sender below)
# 3. Create an API key
RESEND_API_KEY=
# Verified sender address. If you skipped domain verification you can
# leave this blank and Resend will deliver from `onboarding@resend.dev`.
RESEND_FROM_EMAIL="RSVPs <rsvps@your-verified-domain.com>"
# Where notifications go (the couple's inbox).
COUPLE_EMAIL=

# --- Admin dashboard (HTTP Basic Auth on /admin) ---------------------------
# If ADMIN_PASSWORD is unset, /admin returns 503 and is unreachable.
ADMIN_USER=admin
ADMIN_PASSWORD=
